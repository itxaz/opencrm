# --- Inspire OPs API configuration ---
# Copy to .env and adjust for your environment.

# HTTP
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Privileged DB connection (table owner) — runs migrations, login lookup, tenant provisioning.
# Bypasses RLS by virtue of owning the tables. Keep this credential server-side only.
DATABASE_URL=postgres://inspire:inspire@localhost:5432/inspire_crm

# Runtime DB connection (non-owner) — used for all tenant-scoped requests. Subject to RLS.
APP_DATABASE_URL=postgres://inspire_app:inspire_app@localhost:5432/inspire_crm

# Auth
JWT_SECRET=dev-only-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
