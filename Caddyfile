# Serves the built SPA on Railway's injected $PORT with SPA fallback + asset caching.
:{$PORT:80} {
	root * /srv
	encode gzip zstd

	# Fingerprinted Vite assets are immutable — cache hard.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Client-side routing: serve index.html for unknown paths.
	try_files {path} /index.html
	file_server
}
